# Pure/spherical basis request smoke input.
# This file documents the GAMESS-compatible ISPHER keyword while OpenQP's
# native backend remains Cartesian-only. It is expected to fail clearly with
# the current implementation until pure/spherical variational/SALC support is added.
[input]
system=water.xyz
runtype=energy
basis=cc-pvdz
method=hf
ispher=1

[scf]
type=rhf
maxit=1
