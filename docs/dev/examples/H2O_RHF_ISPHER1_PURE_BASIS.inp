# Pure/spherical basis request smoke input.
# This file documents the GAMESS-compatible ISPHER keyword. Keep it outside the
# default examples tree until pure/spherical AO-order/integral/SCF validation has
# a stable reference result.
[input]
system=water.xyz
runtype=energy
basis=cc-pvdz
method=hf
ispher=1

[scf]
type=rhf
maxit=1
